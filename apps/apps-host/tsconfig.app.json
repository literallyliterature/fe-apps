{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@note-taker/*": ["../../libs/note-taker/*"],
      "@sudoku/*": ["../../libs/sudoku/*"],
      "@minesweeper/*": ["../../libs/coop-minesweeper/*"]
    }
  },
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "../../libs/**/*.ts",
    "../../libs/**/*.vue"
  ],
  "exclude": ["src/**/__tests__/*"]
}
